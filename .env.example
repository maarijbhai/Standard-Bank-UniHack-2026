# ---------------------------------------------------------------
# Frontend (.env in /frontend)
# Set VITE_API_URL to the ApiGatewayUrl output after `cdk deploy`
# ---------------------------------------------------------------
VITE_API_URL=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/prod

# ---------------------------------------------------------------
# Backend — Lambda environment variables (managed by CDK stack)
# These are injected automatically; listed here for local reference
# ---------------------------------------------------------------
AWS_REGION=us-east-1
DYNAMODB_TABLE=umnyango-sessions
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5
