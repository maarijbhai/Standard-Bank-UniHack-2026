# Copy this file to frontend/.env and fill in real values.
# VITE_API_URL:            REST API Gateway URL (ApiGatewayUrl output from cdk deploy)
# VITE_TRANSCRIBE_WS_URL:  WebSocket URL for Transcribe streaming (TranscribeWsUrl output)
# VITE_LOCATION_API_KEY:   Amazon Location Service API key (leave blank if unused)
VITE_API_URL=
VITE_TRANSCRIBE_WS_URL=
VITE_LOCATION_API_KEY=
